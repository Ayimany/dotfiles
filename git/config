[include]
    path = /home/ayimany/.config/delta/themes/catppuccin.gitconfig
    path = /home/ayimany/.config/git/user

[init]
    defaultBranch = main

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    nagivate = true
    side-by-side = true
    line-numbers = true
    features = catppuccin-mocha

[merge]
    conflictStyle = diff3

[diff]
    colorMoved = default
